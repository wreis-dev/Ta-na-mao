# Copie para .env e preencha localmente. NUNCA comite valores reais.

# Postgres usado pelo Prisma. Use um DB local ou de dev.
DATABASE_URL="postgresql://user:password@localhost:5432/ta_na_mao?schema=public"

# YouTube Data API (apenas metadados publicos no MVP). NAO commitar.
# YouTube usa API key (publico) ou OAuth 2.0 (privado). NAO use OAuth 1.0.
# YOUTUBE_API_KEY=""

# Trello / OAuth 1.0 (DEV-002A). NAO commitar valores reais.
# Apenas o protocolo OAuth 1.0 HMAC-SHA1 e suportado pelo Trello.
# TRELLO_OAUTH_CONSUMER_KEY=""
# TRELLO_OAUTH_CONSUMER_SECRET=""
# TRELLO_OAUTH_ACCESS_TOKEN=""
# TRELLO_OAUTH_TOKEN_SECRET=""
